{
  "name": "lucky-sevens-slots",
  "version": "1.0.0",
  "description": "Professional Vegas-style slots game with Node.js and MySQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "server": "node src/server.js",
    "client": "vite",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "db:setup": "mysql -u root -p < database.sql",
    "generate:icons": "node scripts/generate-placeholders.js"
  },
  "keywords": [
    "slots",
    "casino",
    "game",
    "nodejs",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "framer-motion": "^12.38.0",
    "mysql2": "^3.6.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "vite": "^8.0.1"
  }
}
